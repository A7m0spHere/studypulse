{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StudyPulse",
  "version": "0.2.3",
  "identifier": "com.studypulse.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "StudyPulse",
        "width": 1180,
        "height": 780,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": ["icons/icon.ico"],
    "windows": {}
  }
}
